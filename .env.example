# ─── Server ───────────────────────────────────────────────
SERVER_PORT=3443

# ─── TOTP Settings (RFC 6238 §4.1) ───────────────────────
# Time step in seconds. RFC recommends 30.
TOTP_TIME_STEP=30

# T0: Unix time to start counting from. Default is 0 (epoch).
TOTP_T0=0

# Number of digits in the generated code.
TOTP_DIGITS=6

# ─── Key Encryption (RFC 6238 §5.1) ──────────────────────
# Master key for AES-256-GCM encryption of user secrets.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# This key protects all stored TOTP shared secrets.
MASTER_ENCRYPTION_KEY=

# ─── Gmail SMTP ───────────────────────────────────────────
# Your Gmail address
GMAIL_USER=
# App Password (NOT your regular password)
# Generate at: Google Account → Security → 2-Step Verification → App Passwords
GMAIL_APP_PASSWORD=

# ─── TLS Certificates ────────────────────────────────────
# Paths to your self-signed cert and key (see certs/README.md)
TLS_CERT_PATH=./certs/server.crt
TLS_KEY_PATH=./certs/server.key
